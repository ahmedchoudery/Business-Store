{
    "version": 2,
    "public": true,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api).*)*",
            "destination": "/index.html"
        }
    ],
    "framework": "vite",
    "installCommand": "npm run install:all",
    "buildCommand": "npm run build"
}