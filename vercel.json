{
    "version": 2,
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api).*)*",
            "destination": "/index.html"
        }
    ],
    "cleanUrls": true
}