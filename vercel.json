{
    "version": 2,
    "public": true,
    "framework": null,
    "functions": {
        "api/index.js": {
            "runtime": "nodejs20.x"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api).*)*",
            "destination": "/index.html"
        }
    ],
    "installCommand": "npm run install:all",
    "buildCommand": "npm run build"
}