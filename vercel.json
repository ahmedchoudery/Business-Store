{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "client/dist",
    "installCommand": "npm install && cd client && npm install",
    "functions": {
        "server-api/index.js": {
            "maxDuration": 10
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/server-api/index.js"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    }
}