{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/assets/:path*",
            "destination": "/public/assets/:path*"
        },
        {
            "source": "/((?!api).*)*",
            "destination": "/public/index.html"
        }
    ],
    "cleanUrls": true
}