{
    "name": "business-store-monorepo",
    "version": "1.0.0",
    "private": true,
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-validator": "^7.1.0",
        "helmet": "^7.1.0",
        "mongoose": "^8.4.1"
    },
    "engines": {
        "node": "20.x"
    },
    "devDependencies": {
        "shx": "^0.4.0"
    },
    "scripts": {
        "install:client": "cd client && npm install",
        "build:client": "cd client && npm run build",
        "build": "npm run install:client && npm run build:client && npx shx rm -rf dist && npx shx mkdir -p dist && npx shx cp -r client/dist/* dist/",
        "start": "node api/index.js"
    }
}
