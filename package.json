{
    "name": "business-store-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "Premium Business Store Project with Clean Architecture",
    "engines": {
        "node": "20.x"
    },
    "scripts": {
        "install:all": "npm install && cd client && npm install",
        "build": "cd client && npm install && npm run build",
        "dev:server": "node --watch server/index.js",
        "dev:client": "cd client && npm run dev",
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "start": "node api/index.js"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-validator": "^7.1.0",
        "helmet": "^7.1.0",
        "mongoose": "^8.4.1"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "shx": "^0.4.0"
    }
}